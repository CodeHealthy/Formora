# API
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=formora
# Use only a disposable database; integration tests delete its collections.
MONGODB_TEST_URI=mongodb://localhost:27017/formora-test?replicaSet=rs0&directConnection=true
SESSION_TTL_HOURS=168

# Web (values exposed to the browser must start with VITE_)
VITE_API_BASE_URL=http://localhost:3000/api/v1
